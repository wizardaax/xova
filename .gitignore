# Build artefacts
**/node_modules/
**/dist/
**/target/
**/build/
**/.next/
**/.turbo/
**/htmlcov/
**/__pycache__/
*.pyc
*.pdb
*.lib
*.tmp

# Tauri
**/src-tauri/target/

# Local runtime state — user-private; back up via scheduled XovaBackup task.
memory/*.json
memory/*.jsonl
memory/*.log
memory/*.txt
memory/*.md
memory/*.png
memory/*.jpg
memory/*.wav
memory/cycles/
memory/evolution/
memory/chat_log/
memory/audit/
memory/audit2/
memory/audit3/
memory/audit4/
memory/audit5/
memory/voice_memos/
memory/voice_profile/
memory/uploads/
memory/sessions/
memory/exports/
memory/xova_shell/
memory/phone_notes/

# Per-agent recycle bin (append-only, managed by trash_keeper.py)
trash/
trash-absorb/

# Browser control runtime data
browser_data/

# Alternative build target (non-standard)
app/src-tauri/target_new/

# IDE
.vscode/
.idea/
*.code-workspace

# OS
Thumbs.db
.DS_Store

# Generated audio (rebuild via `python plugins/sound_wave.py`)
plugins/*.wav
plugins/plugins/*.wav

# Lockfiles you might or might not want — leaving included by default
# package-lock.json, pnpm-lock.yaml, Cargo.lock — keep these in git
